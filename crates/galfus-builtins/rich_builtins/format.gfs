fn parseFloat32(s: [uint8]): ParseResult<float32> {
  var value: float64 = 0.0
  var fraction: float64 = 0.0
  var divisor: float64 = 10.0
  var negative = false
  var hasWholeDigit = false
  var hasFractionDigit = false
  var afterDot = false
  var index = 0

  for byte in s {
    if index == 0 && byte == 45 {
      negative = true
    } else if byte == 46 {
      if afterDot || !hasWholeDigit {
        return ParseResult<float32>::Err("invalid float")
      }

      afterDot = true
    } else {
      if byte < 48 || byte > 57 {
        return ParseResult<float32>::Err("invalid digit")
      }

      var digit = <float64> (byte - 48)

      if afterDot {
        hasFractionDigit = true
        fraction = fraction + digit / divisor
        divisor = divisor * 10.0
      } else {
        hasWholeDigit = true
        value = value * 10.0 + digit
      }
    }
    index += 1
  }

  if !hasWholeDigit {
    return ParseResult<float32>::Err("empty input")
  }

  if !afterDot || !hasFractionDigit {
    return ParseResult<float32>::Err("invalid float")
  }

  value = value + fraction

  if negative {
    return ParseResult<float32>::Ok(-value)
  }

  return ParseResult<float32>::Ok(value)
}

fn parseFloat64(s: [uint8]): ParseResult<float64> {
  var value: float64 = 0.0
  var fraction: float64 = 0.0
  var divisor: float64 = 10.0
  var negative = false
  var hasWholeDigit = false
  var hasFractionDigit = false
  var afterDot = false
  var index = 0

  for byte in s {
    if index == 0 && byte == 45 {
      negative = true
    } else if byte == 46 {
      if afterDot || !hasWholeDigit {
        return ParseResult<float64>::Err("invalid float")
      }

      afterDot = true
    } else {
      if byte < 48 || byte > 57 {
        return ParseResult<float64>::Err("invalid digit")
      }

      var digit = <float64> (byte - 48)

      if afterDot {
        hasFractionDigit = true
        fraction = fraction + digit / divisor
        divisor = divisor * 10.0
      } else {
        hasWholeDigit = true
        value = value * 10.0 + digit
      }
    }
    index += 1
  }

  if !hasWholeDigit {
    return ParseResult<float64>::Err("empty input")
  }

  if !afterDot || !hasFractionDigit {
    return ParseResult<float64>::Err("invalid float")
  }

  value = value + fraction

  if negative {
    return ParseResult<float64>::Ok(-value)
  }

  return ParseResult<float64>::Ok(value)
}

fn parseBool(s: [uint8]): ParseResult<bool> {
  return parseBoolRaw(s)
}

fn parseNull(s: [uint8]): ParseResult<null> {
  if length(s) == 4 {
    var ok = true
    var index = 0
    for byte in s {
      if index == 0 && byte != 110 {
        ok = false
      }
      if index == 1 && byte != 117 {
        ok = false
      }
      if index == 2 && byte != 108 {
        ok = false
      }
      if index == 3 && byte != 108 {
        ok = false
      }
      index += 1
    }

    if ok {
      return ParseResult<null>::Ok(null)
    }
  }

  return ParseResult<null>::Err("invalid null")
}

export fn parse<T: Parsed>(s: [uint8]): ParseResult<T> {
  return typeof T {
    int8 => parseInt8(s),
    int16 => parseInt16(s),
    int32 => parseInt32(s),
    int64 => parseInt64(s),

    uint8 => parseUint8(s),
    uint16 => parseUint16(s),
    uint32 => parseUint32(s),
    uint64 => parseUint64(s),

    float32 => parseFloat32(s),
    float64 => parseFloat64(s),

    bool => parseBool(s),
    null => parseNull(s),

    _ => ParseResult<T>::Err("unsupported type for parse")
  }
}
