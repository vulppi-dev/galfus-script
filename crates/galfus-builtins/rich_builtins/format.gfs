fn parseFloat32(s: [u8]): ParseResult<f32> {
  var value: f64 = 0.0
  var fraction: f64 = 0.0
  var divisor: f64 = 10.0
  var negative = false
  var hasWholeDigit = false
  var hasFractionDigit = false
  var afterDot = false
  var index = 0

  for byte in s {
    if index == 0 && byte == 45 {
      negative = true
    } else if byte == 46 {
      if afterDot || !hasWholeDigit {
        return ParseResult<f32>::Err("invalid float")
      }

      afterDot = true
    } else {
      if byte < 48 || byte > 57 {
        return ParseResult<f32>::Err("invalid digit")
      }

      var digit = <f64> (byte - 48)

      if afterDot {
        hasFractionDigit = true
        fraction = fraction + digit / divisor
        divisor = divisor * 10.0
      } else {
        hasWholeDigit = true
        value = value * 10.0 + digit
      }
    }
    index += 1
  }

  if !hasWholeDigit {
    return ParseResult<f32>::Err("empty input")
  }

  if !afterDot || !hasFractionDigit {
    return ParseResult<f32>::Err("invalid float")
  }

  value = value + fraction

  if negative {
    return ParseResult<f32>::Ok(-value)
  }

  return ParseResult<f32>::Ok(value)
}

fn parseFloat64(s: [u8]): ParseResult<f64> {
  var value: f64 = 0.0
  var fraction: f64 = 0.0
  var divisor: f64 = 10.0
  var negative = false
  var hasWholeDigit = false
  var hasFractionDigit = false
  var afterDot = false
  var index = 0

  for byte in s {
    if index == 0 && byte == 45 {
      negative = true
    } else if byte == 46 {
      if afterDot || !hasWholeDigit {
        return ParseResult<f64>::Err("invalid float")
      }

      afterDot = true
    } else {
      if byte < 48 || byte > 57 {
        return ParseResult<f64>::Err("invalid digit")
      }

      var digit = <f64> (byte - 48)

      if afterDot {
        hasFractionDigit = true
        fraction = fraction + digit / divisor
        divisor = divisor * 10.0
      } else {
        hasWholeDigit = true
        value = value * 10.0 + digit
      }
    }
    index += 1
  }

  if !hasWholeDigit {
    return ParseResult<f64>::Err("empty input")
  }

  if !afterDot || !hasFractionDigit {
    return ParseResult<f64>::Err("invalid float")
  }

  value = value + fraction

  if negative {
    return ParseResult<f64>::Ok(-value)
  }

  return ParseResult<f64>::Ok(value)
}

fn parseBool(s: [u8]): ParseResult<bool> {
  return parseBoolRaw(s)
}

fn parseNull(s: [u8]): ParseResult<null> {
  if length(s) == 4 {
    var ok = true
    var index = 0
    for byte in s {
      if index == 0 && byte != 110 {
        ok = false
      }
      if index == 1 && byte != 117 {
        ok = false
      }
      if index == 2 && byte != 108 {
        ok = false
      }
      if index == 3 && byte != 108 {
        ok = false
      }
      index += 1
    }

    if ok {
      return ParseResult<null>::Ok(null)
    }
  }

  return ParseResult<null>::Err("invalid null")
}

export fn parse<T: Parsed>(s: [u8]): ParseResult<T> {
  return typeof T {
    i8 => parseInt8(s),
    i16 => parseInt16(s),
    i32 => parseInt32(s),
    i64 => parseInt64(s),

    u8 => parseUint8(s),
    u16 => parseUint16(s),
    u32 => parseUint32(s),
    u64 => parseUint64(s),

    f32 => parseFloat32(s),
    f64 => parseFloat64(s),

    bool => parseBool(s),
    null => parseNull(s),

    _ => ParseResult<T>::Err("unsupported type for parse")
  }
}
