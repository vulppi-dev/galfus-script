fn __builtin_write(text: [uint8]): null {}
fn __builtin_read(): [uint8] {
  return ""
}

export fn read(): [uint8] {
  return __builtin_read()
}

export fn print(text: [uint8]): null {
  __builtin_write(text)
}

export fn println(text: [uint8]): null {
  __builtin_write(text)
  __builtin_write([<uint8>10])
}
