fn __builtin_write(text: [u8]): null {}
fn __builtin_read(terminator: [u8]): [u8] {
  return ""
}

export fn read(terminator: [u8] = "\n"): [u8] {
  return __builtin_read(terminator)
}

export fn print(text: [u8]): null {
  __builtin_write(text)
}

export fn println(text: [u8]): null {
  __builtin_write(text)
  __builtin_write([<u8>10])
}

