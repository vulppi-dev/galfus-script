import { println, read } from 'std/io'
import { stringify, parse, Result } from 'format'
import { cyan } from 'format/ansi'
import { trim } from 'text'


export fn main(_args: [[u8]]): i32 {
  var value = match parse<i32>(trim(read())) {
    Result::Ok(v) => v,
    Result::Err(e) => 0,
  }

  println(cyan()::apply(stringify(value + 10)))

  return 0
}
