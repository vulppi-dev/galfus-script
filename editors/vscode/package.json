{
  "name": "galfus-language",
  "version": "0.0.1",
  "homepage": "https://galfus.com/",
  "repository": {
    "type": "git",
    "url": "https://github.com/vulppi-dev/galfus-script.git",
    "directory": "editors/vscode"
  },
  "bugs": {
    "url": "https://github.com/vulppi-dev/galfus-script/issues"
  },
  "license": "MIT",
  "categories": [
    "Programming Languages"
  ],
  "contributes": {
    "languages": [
      {
        "id": "galfus",
        "aliases": [
          "Galfus",
          "galfus"
        ],
        "extensions": [
          ".gfs"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "galfus",
        "scopeName": "source.gfs",
        "path": "./syntaxes/galfus.tmLanguage.json"
      }
    ]
  },
  "module": "index.ts",
  "type": "module",
  "scripts": {},
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "typescript": "^7.0.2"
  }
}
