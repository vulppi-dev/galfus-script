{
  "name": "galfus-language",
  "version": "0.0.2",
  "description": "Syntax highlighting and basic editor support for Galfus Script.",
  "displayName": "Galfus Script",
  "publisher": "galfus",
  "icon": "./assets/brand-128.png",
  "homepage": "https://galfus.com/",
  "repository": {
    "type": "git",
    "url": "https://github.com/vulppi-dev/galfus-script.git",
    "directory": "editors/vscode"
  },
  "bugs": {
    "url": "https://github.com/vulppi-dev/galfus-script/issues"
  },
  "license": "MIT",
  "engines": {
    "vscode": "^1.128.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "keywords": [
    "galfus",
    "galfus-script",
    "language",
    "syntax-highlighting"
  ],
  "contributes": {
    "languages": [
      {
        "id": "galfus",
        "aliases": [
          "Galfus Script",
          "Galfus",
          "galfus"
        ],
        "extensions": [
          ".gfs",
          ".gfp"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "dark": "./assets/icon-128.png",
          "light": "./assets/icon-128.png"
        }
      }
    ],
    "grammars": [
      {
        "language": "galfus",
        "scopeName": "source.gfs",
        "path": "./syntaxes/galfus.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "galfus",
        "path": "./snippets/galfus.json"
      }
    ]
  },
  "type": "module",
  "scripts": {
    "check": "bun check:types && bun check:extension",
    "check:types": "tsc --noEmit",
    "check:extension": "bun scripts/check.ts",
    "dev": "code --extensionDevelopmentPath=\"$(pwd)\" --new-window \"$(realpath ../../examples/project)\"",
    "pkg:ls": "vsce ls --tree",
    "pkg": "bun check && bun scripts/pack.ts"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "typescript": "^7.0.2"
  }
}
