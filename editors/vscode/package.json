{
  "name": "galfus-language",
  "displayName": "Galfus Script",
  "description": "Syntax highlighting and basic editor support for Galfus Script.",
  "version": "0.0.1",
  "publisher": "galfus",
  "homepage": "https://galfus.com/",
  "repository": {
    "type": "git",
    "url": "https://github.com/vulppi-dev/galfus-script.git",
    "directory": "editors/vscode"
  },
  "bugs": {
    "url": "https://github.com/vulppi-dev/galfus-script/issues"
  },
  "license": "MIT",
  "engines": {
    "vscode": "^1.60.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "keywords": [
    "galfus",
    "galfus-script",
    "language",
    "syntax-highlighting"
  ],
  "contributes": {
    "languages": [
      {
        "id": "galfus",
        "aliases": [
          "Galfus Script",
          "Galfus",
          "galfus"
        ],
        "extensions": [
          ".gfs",
          ".gfp"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "galfus",
        "scopeName": "source.gfs",
        "path": "./syntaxes/galfus.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "galfus",
        "path": "./snippets/galfus.json"
      }
    ]
  },
  "type": "module",
  "scripts": {},
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "typescript": "^7.0.2"
  }
}
