{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Galfus Script",
  "scopeName": "source.gfs",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#keywords" },
    { "include": "#decorators" },
    { "include": "#operators" },
    { "include": "#types" },
    { "include": "#numbers" },
    { "include": "#function-calls" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.gfs",
          "match": "//.*$"
        },
        {
          "name": "comment.block.gfs",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.gfs",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.gfs",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.quoted.single.gfs",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.gfs",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "decorators": {
      "patterns": [
        {
          "name": "meta.annotation.gfs",
          "match": "@[a-zA-Z_][a-zA-Z0-9_]*"
        }
      ]
    },
    "function-calls": {
      "patterns": [
        {
          "name": "entity.name.function.gfs",
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.gfs",
          "match": "\\b(import|from|export|fn|var|const|struct|enum|choice|constraint|type|external|if|else|for|in|loop|break|continue|return|match|instanceof|transaction|rollback|weak|satisfies|new|copy|self)\\b"
        },
        {
          "name": "constant.language.gfs",
          "match": "\\b(true|false|null)\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.namespace.gfs",
          "match": "::"
        },
        {
          "name": "keyword.operator.comparison.gfs",
          "match": "==|!=|<=|>=|<|>"
        },
        {
          "name": "keyword.operator.assignment.gfs",
          "match": "\\+=|-=\\*=|/=|%=|="
        },
        {
          "name": "keyword.operator.logical.gfs",
          "match": "&&|\\|\\||!"
        },
        {
          "name": "keyword.operator.arithmetic.gfs",
          "match": "\\+|-|\\*|/|%"
        },
        {
          "name": "keyword.operator.range.gfs",
          "match": "\\.\\."
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "support.type.primitive.gfs",
          "match": "\\b(null|bool|int8|int16|int32|int64|int128|int|uint8|uint16|uint32|uint64|uint128|uint|float32|float64|float)\\b"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.gfs",
          "match": "\\b\\d+\\.\\d+\\b"
        },
        {
          "name": "constant.numeric.integer.gfs",
          "match": "\\b\\d+\\b"
        }
      ]
    }
  }
}
